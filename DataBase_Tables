CREATE TABLE DOCTORS (
    DOCTOR_ID NUMBER PRIMARY KEY,
    DOC_NAME VARCHAR2(100) NOT NULL,
    SPECIALIZATION VARCHAR2(100) NOT NULL,
    PHONE VARCHAR2(15),
    EMAIL VARCHAR2(100),
);

CREATE TABLE PATIENTS(
    PATIENT_ID NUMBER PRIMARY KEY,
    PAT_NAME VARCHAR2(100) NOT NULL,
    GENDER CHAR(6),
    DOB DATE,
    AGE NUMBER,
    CONTACT NUMBER,
    ADDRESS VARCHAR2(100),
    DOC_ID NUMBER REFERENCES DOCTORS(DOCTOR_ID) ON DELETE SET NULL
);

CREATE TABLE WARD(
WARD_ID NUMBER PRIMARY KEY,
WARD_NAME VARCHAR2(50),
WARD_TYPE VARCHAR2(50),
TOTAL_BEDS NUMBER,
AVAIL_BEDS NUMBER
)

CREATE TABLE APPOINTMENT(
    APPOINTMENT_NO NUMBER PRIMARY KEY,
    PAT_ID NUMBER REFERENCES PATIENTS(PATIENT_ID) ON DELETE SET NULL,
    DOC_ID NUMBER REFERENCES DOCTORS(DOCTOR_ID) ON DELETE SET NULL,
    APPOINTMENT_DATE DATE,
    WARD_ID NUMBER REFERENCES WARD(WARD_ID) ON DELETE SET NULL
);

CREATE TABLE PHARMACY
(
MEDICINE_ID NUMBER PRIMARY KEY,
MED_NAME VARCHAR2(50),
MED_TYPE VARCHAR2(50),
MANU_DATE DATE,
EXP_DATE DATE,
PRICE NUMBER
)

CREATE TABLE BILL_HEADER (
    BILL_NO NUMBER PRIMARY KEY,
    PID NUMBER NOT NULL,                     
    SUB_TOTAL NUMBER(10,2) DEFAULT 0,
    TAX_AMOUNT NUMBER(10,2) DEFAULT 0,
    DISCOUNT NUMBER(10,2) DEFAULT 0,
    NET_AMOUNT NUMBER(10,2) DEFAULT 0,
    PAYMENT_METHOD VARCHAR2(50),
    FOREIGN KEY (PID) REFERENCES PATIENTS(PATIENT_ID) ON DELETE SET NULL
);

CREATE TABLE BILL_DETAILS (
    DETAIL_ID NUMBER PRIMARY KEY,
    BILL_NO NUMBER NOT NULL,
    SERVICE_DESC VARCHAR2(100) NOT NULL,
    QTY NUMBER NOT NULL,
    RATE NUMBER(10,2) NOT NULL,
    LINE_TOTAL NUMBER(10,2) NOT NULL,
    FOREIGN KEY (BILL_NO) REFERENCES BILL_HEADER(BILL_NO) ON DELETE CASCADE
);

CREATE SEQUENCE seq_bill_no 
START WITH 1000 
INCREMENT BY 1;

CREATE SEQUENCE seq_bill_detail 
START WITH 1
INCREMENT BY 1;
